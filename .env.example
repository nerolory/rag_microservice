# Provider selection: openai | local
EMBEDDING_PROVIDER=local
# Provider selection: openrouter | openai
LLM_PROVIDER=openai

# OpenAI-compatible API (cloud embeddings and/or LLM, e.g. OpenAI or Groq)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local embeddings (sentence-transformers, no API key)
LOCAL_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
LOCAL_EMBEDDING_DEVICE=cpu
EMBEDDING_OPERATION_TIMEOUT_SECONDS=300
WARMUP_LOCAL_EMBEDDINGS=true

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=documents

# RAG tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=0.15
TOP_K=5

# Logging
LOG_LEVEL=INFO

# --- How to run ---
# Docker:
#   docker compose up -d app
#   or: .\scripts\run_docker.ps1
# Without Docker:
#   pip install -e ".[local]"
#   python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
#
# API docs: http://localhost:8000/docs
